{
  "manifest_version": 3,
  "name": "Shopee Scraper",
  "version": "1.0.0",
  "description": "Scrape produk dari halaman pencarian Shopee secara otomatis",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": ["*://shopee.co.id/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://shopee.co.id/search*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["*://shopee.co.id/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shopee Scraper"
  }
}
